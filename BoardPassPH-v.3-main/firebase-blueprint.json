{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account profile tracking credentials, boards syllabus progress, XP metrics, habits, RPG elements, and study duration data.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Unique email address for registration, lowercased."
        },
        "tier": {
          "type": "string",
          "enum": ["Free", "Pro", "Clinical", "Clinical Trial", "7-Day Clinical Trial", "Pro Suite", "Clinical Suite"],
          "description": "Access tier status."
        },
        "adaptive": {
          "type": "boolean",
          "description": "Whether exam adaptation mode is active."
        },
        "username": {
          "type": "string"
        },
        "school": {
          "type": "string"
        },
        "photo": {
          "type": "string"
        },
        "totalXp": {
          "type": "number"
        },
        "streak": {
          "type": "number"
        },
        "streakShields": {
          "type": "number"
        },
        "lastDate": {
          "type": "string"
        },
        "currentCombo": {
          "type": "number"
        },
        "attempts": {
          "type": "number"
        },
        "correct": {
          "type": "number"
        },
        "signUpDate": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "petName": {
          "type": "string"
        },
        "petSpecies": {
          "type": "string",
          "enum": ["frog", "kitty", "pup", "owl"]
        },
        "petHappiness": {
          "type": "number"
        }
      },
      "required": ["email", "tier", "totalXp", "streak"]
    },
    "FeedbackPayload": {
      "title": "FeedbackPayload",
      "description": "Syllabus feedback, quality reports, and billing tickets composed by candidate reviewees.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "rating": {
          "type": "number"
        },
        "message": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["email", "topic", "message", "timestamp"]
    },
    "GCashPaymentRequest": {
      "title": "GCashPaymentRequest",
      "description": "Payment requests uploaded via gcash confirmation matching target upgrade options.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "requestedTier": {
          "type": "string"
        },
        "amountPaid": {
          "type": "number"
        },
        "gcashNumber": {
          "type": "string"
        },
        "gcashReceiver": {
          "type": "string"
        },
        "gcashRef": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "rejectionReason": {
          "type": "string"
        }
      },
      "required": ["id", "email", "amountPaid", "gcashNumber", "gcashRef", "status"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Official updates from PRC and clinical study tasks managed by board administrators.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "desc": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": ["id", "tag", "title", "date", "desc"]
    },
    "Question": {
      "title": "Question",
      "description": "Clinical diagnostic vignette scenarios.",
      "type": "object",
      "properties": {
        "category": {
          "type": "string"
        },
        "vignette": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctIndex": {
          "type": "number"
        },
        "explanation": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": ["category", "vignette", "options", "correctIndex", "explanation"]
    }
  },
  "firestore": {
    "/profiles/{email}": {
      "schema": "UserProfile",
      "description": "Master clinical record for active reviewees by email id."
    },
    "/feedbacks/{feedbackId}": {
      "schema": "FeedbackPayload",
      "description": "Global bug and content correction reports."
    },
    "/gcash_requests/{requestId}": {
      "schema": "GCashPaymentRequest",
      "description": "Active GCash verification ticket pool for administrative upgrades."
    },
    "/custom_announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "News flashes and board schedules displayed in Bulletins."
    },
    "/custom_seed_questions/{questionId}": {
      "schema": "Question",
      "description": "Custom peer-submitted questions from community review boards."
    }
  }
}
