rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email.lower() == email.lower();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'dsmind.pmle@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@\\+]+$');
    }

    // Entities schema checking
    function isValidUserProfile(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.tier is string && data.tier.size() <= 50 &&
             data.totalXp is int && data.totalXp >= 0 &&
             data.streak is int && data.streak >= 0;
    }

    function isValidFeedback(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.topic is string && data.topic.size() <= 100 &&
             data.message is string && data.message.size() <= 10000;
    }

    function isValidGCashRequest(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.amountPaid is number && data.amountPaid >= 0 &&
             data.gcashNumber is string && data.gcashNumber.size() <= 20 &&
             data.gcashRef is string && data.gcashRef.size() <= 100 &&
             data.status is string && data.status.size() <= 20;
    }

    // Rule definitions for each collection
    match /profiles/{email} {
      allow read, write: if true;
    }

    match /test/{document} {
      allow read, write: if true;
    }

    match /feedbacks/{feedbackId} {
      allow read, write: if true;
    }

    match /gcash_requests/{requestId} {
      allow read, write: if true;
    }

    match /custom_announcements/{announcementId} {
      allow read, write: if true;
    }

    match /custom_seed_questions/{questionId} {
      allow read, write: if true;
    }

    match /leaderboard/{email} {
      allow read, write: if true;
    }

    match /groupRooms/{roomId} {
      allow read, write: if true;
    }

    match /flashcardDecks/{deckId} {
      allow read, write: if true;
    }

    match /liveRecallSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
